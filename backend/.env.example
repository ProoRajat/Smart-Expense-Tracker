# Copy to .env and fill in values. See backend/PROVIDE.md for where to get these.

# Required: secret for signing JWTs (use a long random string)
JWT_SECRET=your-super-secret-key-at-least-32-chars

# Optional: port (default 3001)
PORT=3001

# Optional: SQLite DB file path (default ./data/expenses.db)
# DATABASE_PATH=./data/expenses.db

# Optional: CORS origin (frontend URL, e.g. http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# Optional: for "forgot password" email (not implemented yet)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@yourapp.com
